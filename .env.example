# =============================================================================
# LLM Self-Consistent Error Measurement - API Keys
# =============================================================================
# Copy this file to .env and fill in your API keys
# DO NOT commit .env to version control!

# =============================================================================
# COMMERCIAL API KEYS (Black-box models)
# =============================================================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google/Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# xAI (Grok) API Key
# Get from: https://console.x.ai/
XAI_API_KEY=

# Groq API Key (Llama 4 Maverick, etc.)
# Get from: https://console.groq.com/
GROQ_API_KEY=

# OpenRouter API Key (Qwen3 Next 80B, etc.)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# =============================================================================
# OPEN-SOURCE MODEL ACCESS
# =============================================================================

# HuggingFace API Token (for open-source models via Inference API)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# Alternative HuggingFace key name (some tools use this)
# HUGGINGFACE_API_KEY=

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Uncomment to enable debug logging
# DEBUG=true

# Uncomment to set a custom results directory
# RESULTS_DIR=data/results
